{
    "buildCommand": "cd frontend && npm run build",
    "outputDirectory": "frontend/.next",
    "rewrites": [
        {
            "source": "/((?!api|static|_next|.*\\..*).*)",
            "destination": "/frontend/"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ]
}